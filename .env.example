# Application Configuration
NODE_ENV=development
PORT=3000
APP_NAME=time-off-microservice
APP_VERSION=1.0.0

# Database Configuration (SQLite)
DB_TYPE=sqlite
DB_DATABASE=./data/time-off.db
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_ENTITIES=src/**/*.entity.ts
DB_MIGRATIONS=src/migrations/*.ts
DB_SUBSCRIBERS=src/subscribers/*.ts

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# HCM System Configuration
HCM_BASE_URL=https://api.hcm-company.com
HCM_API_KEY=your-hcm-api-key
HCM_TIMEOUT=5000
HCM_RETRY_ATTEMPTS=3
HCM_RATE_LIMIT=100

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=7d

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_DATE_PATTERN=YYYY-MM-DD

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000

# Business Configuration
DEFAULT_MIN_NOTICE_DAYS=3
MAX_REQUEST_DAYS_PER_TRANSACTION=365
FRACTIONAL_DAY_INCREMENT=0.5
SYNC_BATCH_SIZE=500
SYNC_CONCURRENCY=10
CACHE_TTL_BALANCE=300
CACHE_TTL_POLICIES=3600

# External Services
WEBHOOK_SECRET=your-webhook-secret
NOTIFICATION_SERVICE_URL=https://api.notifications.com
