# Test Environment Configuration
NODE_ENV=test
PORT=3001
APP_NAME=time-off-microservice-test
APP_VERSION=1.0.0

# Database Configuration (SQLite in-memory for tests)
DB_TYPE=sqlite
DB_DATABASE=:memory:
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_ENTITIES=src/**/*.entity.ts
DB_MIGRATIONS=
DB_SUBSCRIBERS=

# Redis Configuration (disabled for tests)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=

# HCM System Configuration (mock)
HCM_BASE_URL=http://localhost:3001
HCM_API_KEY=test-api-key
HCM_TIMEOUT=5000
HCM_RETRY_ATTEMPTS=3
HCM_RATE_LIMIT=100

# JWT Configuration
JWT_SECRET=test-jwt-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=test-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Security Configuration
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging Configuration
LOG_LEVEL=error
LOG_FILE_PATH=
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_DATE_PATTERN=YYYY-MM-DD

# Monitoring Configuration
METRICS_ENABLED=false
METRICS_PORT=9091
HEALTH_CHECK_INTERVAL=30000

# Business Configuration
DEFAULT_MIN_NOTICE_DAYS=3
MAX_REQUEST_DAYS_PER_TRANSACTION=365
FRACTIONAL_DAY_INCREMENT=0.5
SYNC_BATCH_SIZE=500
SYNC_CONCURRENCY=10
CACHE_TTL_BALANCE=300
CACHE_TTL_POLICIES=3600

# External Services
WEBHOOK_SECRET=test-webhook-secret
NOTIFICATION_SERVICE_URL=
